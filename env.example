# LLM API Keys
GROQ_API_KEY=your_groq_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
HF_TOKEN=your_huggingface_token_here

# LangChain Observability (optional)
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=CONTRACTIQ

# App Config
ENV=local
FAISS_BASE=faiss_index
UPLOAD_BASE=data
FAISS_INDEX_NAME=index
DATA_STORAGE_PATH=data/document_analysis

# Security
SECRET_KEY=generate_with_python_secrets_token_hex_32

# CORS (comma-separated origins for production)
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Redis (optional — app works without it, just no caching)
# REDIS_URL=redis://localhost:6379

# LLM Provider (google or groq)
LLM_PROVIDER=groq
